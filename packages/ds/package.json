{
  "name": "@hb-kit/ds",
  "version": "0.0.1",
  "description": "Hoonbeom Design System",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js",
      "require": "./dist/primitives/index.cjs"
    },
    "./display": {
      "types": "./dist/display/index.d.ts",
      "import": "./dist/display/index.js",
      "require": "./dist/display/index.cjs"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js",
      "require": "./dist/layout/index.cjs"
    },
    "./overlay": {
      "types": "./dist/overlay/index.d.ts",
      "import": "./dist/overlay/index.js",
      "require": "./dist/overlay/index.cjs"
    },
    "./surfaces": {
      "types": "./dist/surfaces/index.d.ts",
      "import": "./dist/surfaces/index.js",
      "require": "./dist/surfaces/index.cjs"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js",
      "require": "./dist/forms/index.cjs"
    },
    "./feedback": {
      "types": "./dist/feedback/index.d.ts",
      "import": "./dist/feedback/index.js",
      "require": "./dist/feedback/index.cjs"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "import": "./dist/navigation/index.js",
      "require": "./dist/navigation/index.cjs"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.js",
      "require": "./dist/lib/utils.cjs"
    },
    "./tokens/default.css": "./dist/tokens/default.css",
    "./tokens/theme.css": "./dist/tokens/theme.css",
    "./tokens/motions.css": "./dist/tokens/motions.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.3.0",
    "embla-carousel-autoplay": "^8.3.0",
    "embla-carousel-react": "^8.3.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^26.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "design-system",
    "react",
    "tailwindcss",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoonbeom1319/hb-kit.git"
  },
  "bugs": {
    "url": "https://github.com/hoonbeom1319/hb-kit/issues"
  },
  "homepage": "https://github.com/hoonbeom1319/hb-kit#readme",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}